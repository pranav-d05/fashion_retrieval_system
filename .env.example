# ============================================================
# Fashion Retrieval System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# --- Qdrant Connection ---
# Local Docker (default): leave as localhost
# Qdrant Cloud: set to your cluster URL, e.g. https://xyz.us-east-1-0.aws.cloud.qdrant.io
QDRANT_LOCAL_PATH=
QDRANT_HOST=localhost

# Qdrant Cloud API key (leave empty for local Docker)
QDRANT_API_KEY=

# --- HuggingFace ---
# Required for downloading models from the HF Hub.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Optional Overrides ---
# Override log level at runtime without editing config.yaml
# LOG_LEVEL=DEBUG
