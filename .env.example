# ============================================================
# Fashion Retrieval System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# --- Qdrant Connection ---
# The default values (local disk mode at .qdrant) are handled in configs/config.yaml.
# Uncomment and override these only if you are using Docker or Qdrant Cloud.
# QDRANT_LOCAL_PATH=
# QDRANT_HOST=localhost
# --- HuggingFace ---
# Required for downloading models from the HF Hub.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# HuggingFace cache — store models on a custom drive if you have limited space on C:
# HF_HOME=D:\hf_cache

# --- Optional Overrides ---
# Override log level at runtime without editing config.yaml
# LOG_LEVEL=DEBUG
